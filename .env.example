# ─── Supabase ──────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Google Calendar Integration ───────────────────────────────
# Follow these steps to get your credentials:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Google Calendar API
# 4. Create OAuth 2.0 credentials (Desktop app)
# 5. Use the refresh token flow to get a refresh token
# 6. Get your Calendar ID from Google Calendar settings

GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_CALENDAR_ID=primary

# ─── Ollama (local AI) ─────────────────────────────────────────
# Make sure Ollama is running: ollama serve
# And the model is pulled: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── OpenRouter (cloud AI fallback) ────────────────────────────
# Get from: https://openrouter.ai/keys
# Free models: https://openrouter.ai/models?q=free
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
